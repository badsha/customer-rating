<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <record id="view_partner_form_customer_rating" model="ir.ui.view">
        <field name="name">res.partner.form.customer.rating</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[contains(@class, 'oe_button_box')]" position="inside">
                <button class="oe_stat_button"
                        name="action_open_customer_rating"
                        type="object"
                        icon="fa-star">
                    <field name="customer_rating_count" widget="statinfo" string="Rating"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='vat']" position="after">
                <field name="customer_rating_stars" widget="html" readonly="1"/>
            </xpath>
        </field>
    </record>
</data>
</odoo>
