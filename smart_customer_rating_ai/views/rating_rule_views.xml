<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rating_rule_list" model="ir.ui.view">
        <field name="name">ll.rating.rule.list</field>
        <field name="model">ll.rating.rule</field>
        <field name="arch" type="xml">
            <list string="Rating Rules">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category" widget="badge" 
                       decoration-info="category == 'value'"
                       decoration-warning="category == 'financial'"
                       decoration-success="category == 'behavioral'"
                       decoration-primary="category == 'ai'"/>
                <field name="metric_key"/>
                <field name="threshold_type"/>
                <field name="threshold_min" string="Threshold"/>
                <field name="score"/>
                <field name="weight"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_rating_rule_form" model="ir.ui.view">
        <field name="name">ll.rating.rule.form</field>
        <field name="model">ll.rating.rule</field>
        <field name="arch" type="xml">
            <form string="Rating Rule">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. High-Value Customer"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="category" widget="radio" options="{'horizontal': true}"/>
                            <field name="metric_key"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="score"/>
                            <field name="weight"/>
                        </group>
                    </group>
                    <group string="Condition &amp; Threshold">
                        <group>
                            <field name="threshold_type"/>
                            <label for="threshold_min" string="Min Threshold" invisible="threshold_type != 'between'"/>
                            <label for="threshold_min" string="Value" invisible="threshold_type == 'between'"/>
                            <div class="o_row">
                                <field name="threshold_min"/>
                                <span invisible="threshold_type != 'between'">to</span>
                                <field name="threshold_max" invisible="threshold_type != 'between'"/>
                            </div>
                        </group>
                        <group>
                            <div class="alert alert-info" role="alert" style="margin-bottom:0px;">
                                <field name="description" nolabel="1"/>
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_rating_rule_search" model="ir.ui.view">
        <field name="name">ll.rating.rule.search</field>
        <field name="model">ll.rating.rule</field>
        <field name="arch" type="xml">
            <search string="Rating Rules">
                <field name="name"/>
                <field name="category"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category'}"/>
                    <filter string="Metric" name="group_by_metric" context="{'group_by': 'metric_key'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_rating_rule" model="ir.actions.act_window">
        <field name="name">Rating Rules</field>
        <field name="res_model">ll.rating.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_rating_rule_search"/>
        <field name="context">{'search_default_group_by_category': 1, 'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first automated rating rule!
            </p><p>
                Choose metrics like Revenue, AUP, or DSO to score your customers automatically.
            </p>
        </field>
    </record>

    <!-- Menuitem for the Rating Rules under Configuration -->
    <menuitem id="menu_rating_rule"
              name="Rating Rules Dashboard"
              parent="menu_customer_rating_config"
              action="action_rating_rule"
              sequence="5"/>
</odoo>
