<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.customer.rating</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Customer Rating" string="Customer Rating" name="smart_customer_rating_ai">
                    <block title="Rating Automation" name="rating_automation_section">
                        <setting title="Recompute Schedule" help="Enable daily automatic rating recalculation.">
                            <field name="ll_rating_auto_recompute"/>
                        </setting>
                        <setting title="Metrics Cache Window"
                                 help="How long deterministic customer metrics are cached before recomputation.">
                            <field name="ll_rating_metrics_cache_hours"/>
                        </setting>
                    </block>
                    <block title="AI Intelligence" name="ai_intelligence_section">
                        <setting title="Enable AI Enrichment"
                                 help="Use AI to interpret structured ERP metrics into risk, loyalty and financial health scores.">
                            <field name="ll_rating_ai_enabled"/>
                        </setting>
                        <setting title="AI Advisory Mode"
                                 help="Choose whether AI advisory values are display-only or blended into automatic final score.">
                            <field name="ll_rating_ai_advisory_mode"/>
                            <div class="content-group" invisible="ll_rating_ai_advisory_mode != 'blend'">
                                <label for="ll_rating_ai_blend_weight" string="Blend Weight"/>
                                <field name="ll_rating_ai_blend_weight"/>
                            </div>
                        </setting>
                        <setting title="AI Provider" help="Choose which AI engine to use for metrics interpretation.">
                            <field name="ll_rating_ai_provider"/>
                            <div class="content-group" invisible="not ll_rating_ai_enabled or ll_rating_ai_provider == 'none'">
                                <div class="mt16" invisible="ll_rating_ai_provider != 'openai'">
                                    <label for="ll_rating_openai_api_key" string="OpenAI Key"/>
                                    <field name="ll_rating_openai_api_key" password="True"/>
                                </div>
                                <div class="mt16" invisible="ll_rating_ai_provider != 'gemini'">
                                    <label for="ll_rating_gemini_api_key" string="Gemini Key"/>
                                    <field name="ll_rating_gemini_api_key" password="True"/>
                                </div>
                                <div class="mt16" invisible="ll_rating_ai_provider != 'ollama'">
                                    <label for="ll_rating_ollama_url" string="Ollama URL"/>
                                    <field name="ll_rating_ollama_url" placeholder="http://localhost:11434"/>
                                    <label for="ll_rating_ollama_model" string="Model" class="mt8"/>
                                    <field name="ll_rating_ollama_model" placeholder="llama3"/>
                                </div>
                                <div class="mt16" invisible="ll_rating_ai_provider != 'custom'">
                                    <setting title="Custom API Endpoint"
                                             help="Configure a custom AI service endpoint. Leave empty to use predefined providers.">
                                        <field name="ll_rating_custom_url" placeholder="https://your-ai-service.com/api/analyze"/>
                                        <field name="ll_rating_custom_api_key" placeholder="Enter your API key"/>
                                        <field name="ll_rating_custom_model" placeholder="Model name (e.g., gpt-4, claude-3)"/>
                                    </setting>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_customer_rating_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'smart_customer_rating_ai'}</field>
    </record>

    <menuitem id="menu_customer_rating_settings"
              name="Settings"
              parent="menu_customer_rating_config"
              action="action_customer_rating_config_settings"
              sequence="100"/>
</odoo>
