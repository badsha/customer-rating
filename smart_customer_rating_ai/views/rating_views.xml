<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <!-- Rated Customers -->
    <record id="view_rated_partner_list" model="ir.ui.view">
        <field name="name">res.partner.rated.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="customer_rating_stars" widget="html" string="Rating"/>
            </list>
        </field>
    </record>

    <!-- Customer Rating Views -->
    <record id="view_customer_rating_list" model="ir.ui.view">
        <field name="name">customer.rating.list</field>
        <field name="model">customer.rating</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="customer_id"/>
                <field name="rating_stars" widget="html" string="Rating"/>
                <field name="rating" optional="hide"/>
                <field name="rating_bucket"
                       widget="badge"
                       decoration-danger="rating_bucket == 'low'"
                       decoration-warning="rating_bucket == 'medium'"
                       decoration-success="rating_bucket == 'high'"/>
            </list>
        </field>
    </record>

    <record id="view_customer_rating_search" model="ir.ui.view">
        <field name="name">customer.rating.search</field>
        <field name="model">customer.rating</field>
        <field name="arch" type="xml">
            <search>
                <field name="customer_id"/>
                <filter name="tag_low" string="Low Tag" domain="[('rating_bucket','=','low')]"/>
                <filter name="tag_medium" string="Medium Tag" domain="[('rating_bucket','=','medium')]"/>
                <filter name="tag_high" string="High Tag" domain="[('rating_bucket','=','high')]"/>
            </search>
        </field>
    </record>

    <record id="view_customer_rating_form" model="ir.ui.view">
        <field name="name">customer.rating.form</field>
        <field name="model">customer.rating</field>
        <field name="arch" type="xml">
            <form string="Customer Rating" create="0">
                <header>
                    <button name="action_recompute_now" type="object"
                            string="Recompute Now" class="btn-primary"
                            invisible="not is_automatic"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="rating_bucket" widget="badge"/>
                        </group>
                        <group>
                            <label for="rating_stars" string="Average Score"/>
                            <div class="o_row">
                                <field name="rating_stars" widget="html" nolabel="1"/>
                                <field name="rating" readonly="1" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Criteria">
                            <field name="criteria_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="name" readonly="1" force_save="1"/>
                                    <field name="score" widget="priority" options="{'max': 5, 'hide_zero': False}"/>
                                    <field name="notes" placeholder="Optional comments..."/>
                                </list>
                            </field>
                        </page>
                        <page string="Rule Insights" invisible="not is_automatic">
                            <field name="insight_ids" readonly="1">
                                <list create="0" delete="0" edit="0"
                                      decoration-success="threshold_met == True"
                                      decoration-muted="threshold_met == False">
                                    <field name="rule_id" string="Rule"/>
                                    <field name="rule_category" widget="badge"
                                           decoration-info="rule_category == 'value'"
                                           decoration-warning="rule_category == 'financial'"
                                           decoration-success="rule_category == 'behavioral'"
                                           decoration-primary="rule_category == 'ai'"/>
                                    <field name="metric_value" string="Measured Value"/>
                                    <field name="ai_provider" string="AI Provider"/>
                                    <field name="points_awarded" string="Points"/>
                                    <field name="threshold_met" string="Met" widget="boolean"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                        <page string="Timeline">
                            <field name="history_ids" readonly="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="changed_on"/>
                                    <field name="changed_by"/>
                                    <field name="change_type"/>
                                    <field name="before_score"/>
                                    <field name="after_score"/>
                                    <field name="summary"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Final Criteria (Template) Views -->
    <record id="view_final_criteria_list" model="ir.ui.view">
        <field name="name">final.criteria.list</field>
        <field name="model">final.criteria</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="criteria_count"/>
            </list>
        </field>
    </record>

    <record id="view_final_criteria_form" model="ir.ui.view">
        <field name="name">final.criteria.form</field>
        <field name="model">final.criteria</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group string="Criteria Items">
                        <field name="line_ids">
                            <list editable="bottom">
                                <field name="name"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_final_criteria_line_delete_wizard_form" model="ir.ui.view">
        <field name="name">final.criteria.line.delete.wizard.form</field>
        <field name="model">final.criteria.line.delete.wizard</field>
        <field name="arch" type="xml">
            <form string="Delete Criteria" class="o_form_dialog">
                <group>
                    <field name="line_id"/>
                </group>
                <footer>
                    <button string="Delete" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Rating breakdown dialog — opened when clicking a row in the contact Ratings tab -->
    <record id="view_customer_rating_dialog" model="ir.ui.view">
        <field name="name">customer.rating.dialog</field>
        <field name="model">customer.rating</field>
        <field name="arch" type="xml">
            <form string="Rating Breakdown" create="0" edit="1">
                <header invisible="not is_automatic">
                    <button name="action_recompute_now" type="object"
                            string="Recompute Now" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="o_row mb-2">
                        <field name="rating_stars" widget="html" nolabel="1"/>
                        <span class="ms-2 fs-5 text-muted">
                            <field name="rating" readonly="1" class="oe_inline"/> / 5
                        </span>
                        <field name="rating_bucket" widget="badge" class="ms-2"
                               decoration-danger="rating_bucket == 'low'"
                               decoration-warning="rating_bucket == 'medium'"
                               decoration-success="rating_bucket == 'high'"/>
                    </div>
                    <!-- Automatic rating: show rule insights -->
                    <group string="Rule Breakdown" invisible="not is_automatic" col="1">
                        <div class="alert alert-info" role="alert"
                             invisible="insight_ids">
                            No rule insights yet. Click "Recompute Now" to evaluate all active rules.
                        </div>
                        <field name="insight_ids" nolabel="1" readonly="1"
                               invisible="not insight_ids">
                            <list create="0" delete="0" edit="0"
                                  decoration-success="threshold_met == True"
                                  decoration-muted="threshold_met == False">
                                <field name="rule_id" string="Rule"/>
                                <field name="rule_category" widget="badge"
                                       decoration-info="rule_category == 'value'"
                                       decoration-warning="rule_category == 'financial'"
                                       decoration-success="rule_category == 'behavioral'"
                                       decoration-primary="rule_category == 'ai'"/>
                                <field name="metric_value" string="Measured"/>
                                <field name="ai_provider" string="AI Provider"/>
                                <field name="points_awarded" string="Points"/>
                                <field name="threshold_met" string="Met" widget="boolean"/>
                            </list>
                        </field>
                    </group>
                    <!-- Manual rating: show criteria scores -->
                    <group string="Criteria Scores" invisible="is_automatic" col="1">
                        <field name="criteria_ids" nolabel="1">
                            <list editable="bottom" create="0" delete="0">
                                <field name="name" string="Criteria" readonly="1" force_save="1"/>
                                <field name="score" widget="priority"
                                       options="{'max': 5, 'hide_zero': False}" force_save="1"/>
                                <field name="notes" string="Notes" force_save="1"/>
                            </list>
                        </field>
                    </group>
                    <group invisible="not notes" col="1">
                        <field name="notes" readonly="0" string="Notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_final_criteria" model="ir.actions.act_window">
        <field name="name">Rating Criteria Templates</field>
        <field name="res_model">final.criteria</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_partner_form_customer_rating_focus" model="ir.ui.view">
        <field name="name">res.partner.form.customer.rating.focus</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <label for="customer_rating_stars" string="Final Rating"/>
                <div class="o_row">
                    <field name="customer_rating_stars" widget="html" readonly="1"/>
                </div>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Ratings" name="customer_rating_tab" autofocus="autofocus">
                    <header>
                        <button name="action_sync_customer_rating" type="object"
                                string="Sync Rating" class="btn-primary"
                                invisible="customer_rating_ids"/>
                    </header>
                    <div class="alert alert-info" role="alert" invisible="customer_rating_id">
                        No rating found for this customer. Click "Sync Rating" to initialize.
                    </div>
                    <div class="alert alert-warning" role="alert"
                         invisible="not selected_manual_rating_id or selected_manual_has_criteria">
                        No criteria are configured for the selected assessment template.
                        Click "Configure Criteria" to add criteria, then click "Sync Rating".
                    </div>
                    <field name="customer_rating_id" invisible="1"/>
                    <field name="customer_rating_ids" invisible="1"/>
                    <group>
                        <field name="customer_rating_ids" nolabel="1"
                               context="{'form_view_ref': 'smart_customer_rating_ai.view_customer_rating_dialog'}">
                            <list create="0" delete="0" edit="0"
                                  decoration-info="is_primary">
                                <field name="is_primary" string="Pri." widget="boolean_toggle"
                                       readonly="1"/>
                                <field name="final_criteria_id" string="Template"/>
                                <field name="rating_stars" widget="html" string="Stars"/>
                                <field name="rating" string="Score"/>
                                <field name="rating_bucket" widget="badge"
                                       decoration-danger="rating_bucket == 'low'"
                                       decoration-warning="rating_bucket == 'medium'"
                                       decoration-success="rating_bucket == 'high'"/>
                                <field name="is_automatic" string="Auto" widget="boolean"/>
                            </list>
                        </field>
                    </group>
                    <separator string="Criteria Details (Manual Rating)"/>
                    <field name="customer_rating_template_id" options="{'no_create': True}"/>
                    <div class="o_row mb-2">
                        <field name="selected_manual_rating_stars" widget="html" readonly="1" nolabel="1"/>
                        <field name="selected_manual_rating_score" readonly="1" class="oe_inline"/>
                    </div>
                    <field name="selected_manual_rating_id" invisible="1"/>
                    <field name="selected_manual_criteria_ids" readonly="1"
                           domain="[('rating_id', '=', selected_manual_rating_id)]">
                        <list create="0" delete="0">
                            <field name="name" readonly="1" force_save="1"/>
                            <field name="score" widget="priority" readonly="1" options="{'max': 5}"/>
                            <field name="notes" readonly="1" placeholder="Optional comments..."/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_customer_rating" model="ir.actions.act_window">
        <field name="name">Rated Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id': ref('view_rated_partner_list')}), (0, 0, {'view_mode': 'form', 'view_id': ref('view_partner_form_customer_rating_focus')})]"/>
        <field name="domain">[('customer_rating_ids', '!=', False)]</field>
        <field name="search_view_id" ref="base.view_res_partner_filter"/>
        <field name="context">{'create': False}</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_customer_rating_root" name="Customer Ratings" action="action_customer_rating" sequence="10"/>

    <menuitem id="menu_customer_rating_config" name="Configuration" parent="menu_customer_rating_root" sequence="90"/>
    <menuitem id="menu_final_criteria" name="Assessment Templates" parent="menu_customer_rating_config" action="action_final_criteria" sequence="10"/>
</data>
</odoo>
