<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_customer_rating" model="ir.ui.view">
        <field name="name">res.partner.form.customer.rating</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <label for="customer_rating_stars" string="Final Rating"/>
                <div class="o_row">
                    <field name="customer_rating_stars" widget="html" readonly="1"/>
                </div>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Ratings" name="customer_rating_tab">
                    <header>
                        <button name="action_sync_customer_rating" type="object"
                                string="Sync Rating" class="btn-primary"
                                invisible="customer_rating_ids"/>
                    </header>
                    <div class="alert alert-info" role="alert" invisible="customer_rating_id">
                        No rating found for this customer. Click "Sync Rating" to initialize.
                    </div>
                    <field name="customer_rating_id" invisible="1"/>
                    <field name="customer_rating_ids" invisible="1"/>
                    <field name="customer_rating_ids" nolabel="1"
                           context="{'form_view_ref': 'smart_customer_rating_ai.view_customer_rating_dialog'}">
                        <list create="0" delete="0" edit="0"
                              decoration-info="is_primary">
                            <field name="is_primary" string="Pri." widget="boolean_toggle"
                                   readonly="1"/>
                            <field name="final_criteria_id" string="Template"/>
                            <field name="rating_stars" widget="html" string="Stars"/>
                            <field name="rating" string="Score"/>
                            <field name="rating_bucket" widget="badge"
                                   decoration-danger="rating_bucket == 'watchlist'"
                                   decoration-warning="rating_bucket == 'rising'"
                                   decoration-success="rating_bucket == 'champion'"/>
                            <field name="is_automatic" string="Auto" widget="boolean"/>
                        </list>
                    </field>
                    <separator string="Criteria Details (Manual Rating)"/>
                    <field name="customer_rating_template_id" options="{'no_create': True}"/>
                    <div class="o_row mb-2">
                        <field name="selected_manual_rating_stars" widget="html" readonly="1" nolabel="1"/>
                        <field name="selected_manual_rating_score" readonly="1" class="oe_inline"/>
                    </div>
                    <field name="selected_manual_rating_id" invisible="1"/>
                    <field name="selected_manual_criteria_ids" readonly="1"
                           domain="[('rating_id', '=', selected_manual_rating_id)]">
                        <list create="0" delete="0">
                            <field name="name" readonly="1" force_save="1"/>
                            <field name="score" widget="priority" readonly="1" options="{'max': 5}"/>
                            <field name="notes" readonly="1" placeholder="Optional comments..."/>
                        </list>
                    </field>
                    <separator string="Data-Driven Insights"/>
                    <group col="2">
                        <group>
                            <field name="ll_metric_avg_payment_delay_days" readonly="1"/>
                            <field name="ll_metric_total_revenue" readonly="1"/>
                            <field name="ll_metric_refund_ratio" readonly="1"/>
                        </group>
                        <group>
                            <field name="ll_metric_risk_score" readonly="1"/>
                            <field name="ll_metric_loyalty_score" readonly="1"/>
                            <field name="ll_metric_financial_health" readonly="1"/>
                        </group>
                    </group>
                    <field name="ll_metric_summary" readonly="1" placeholder="AI summary will appear here."/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
