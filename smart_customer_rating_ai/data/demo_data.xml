<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">
    <record id="demo_template_1" model="final.criteria">
        <field name="name">Standard Evaluation</field>
    </record>

    <record id="demo_template_line_1" model="final.criteria.line">
        <field name="final_id" ref="demo_template_1"/>
        <field name="name">Payment Reliability</field>
    </record>

    <record id="demo_template_line_2" model="final.criteria.line">
        <field name="final_id" ref="demo_template_1"/>
        <field name="name">Communication Efficiency</field>
    </record>

    <record id="res_partner_star" model="res.partner">
        <field name="name">Star Customer LLC</field>
        <field name="is_company">True</field>
        <field name="email">star@example.com</field>
    </record>

    <record id="res_partner_midway" model="res.partner">
        <field name="name">Midway Inc.</field>
        <field name="is_company">True</field>
        <field name="email">midway@example.com</field>
    </record>

    <record id="res_partner_low" model="res.partner">
        <field name="name">Low-Tier Enterprise</field>
        <field name="is_company">True</field>
        <field name="email">low@example.com</field>
    </record>

    <record id="rating_star" model="customer.rating">
        <field name="customer_id" ref="res_partner_star"/>
        <field name="final_criteria_id" ref="demo_template_1"/>
    </record>

    <record id="rating_midway" model="customer.rating">
        <field name="customer_id" ref="res_partner_midway"/>
        <field name="final_criteria_id" ref="demo_template_1"/>
    </record>

    <record id="rating_low" model="customer.rating">
        <field name="customer_id" ref="res_partner_low"/>
        <field name="final_criteria_id" ref="demo_template_1"/>
    </record>

    <record id="rating_star_line_1" model="customer.rating.criteria">
        <field name="rating_id" ref="rating_star"/>
        <field name="name">Payment Reliability</field>
        <field name="score">5</field>
    </record>

    <record id="rating_star_line_2" model="customer.rating.criteria">
        <field name="rating_id" ref="rating_star"/>
        <field name="name">Communication Efficiency</field>
        <field name="score">5</field>
    </record>

    <record id="rating_midway_line_1" model="customer.rating.criteria">
        <field name="rating_id" ref="rating_midway"/>
        <field name="name">Payment Reliability</field>
        <field name="score">4</field>
    </record>

    <record id="rating_midway_line_2" model="customer.rating.criteria">
        <field name="rating_id" ref="rating_midway"/>
        <field name="name">Communication Efficiency</field>
        <field name="score">3</field>
    </record>

    <record id="rating_low_line_1" model="customer.rating.criteria">
        <field name="rating_id" ref="rating_low"/>
        <field name="name">Payment Reliability</field>
        <field name="score">1</field>
    </record>

    <record id="rating_low_line_2" model="customer.rating.criteria">
        <field name="rating_id" ref="rating_low"/>
        <field name="name">Communication Efficiency</field>
        <field name="score">2</field>
    </record>
</data>
</odoo>
