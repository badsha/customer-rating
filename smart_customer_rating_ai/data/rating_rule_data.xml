<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Value: Strong revenue base -->
        <record id="rule_revenue_giant" model="ll.rating.rule">
            <field name="name">Revenue Anchor</field>
            <field name="category">value</field>
            <field name="metric_key">total_revenue</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">20000.0</field>
            <field name="score">100</field>
            <field name="weight">1.8</field>
            <field name="sequence">10</field>
            <field name="active">True</field>
        </record>

        <!-- Value: Healthy average order -->
        <record id="rule_luxury_buyer" model="ll.rating.rule">
            <field name="name">Healthy Order Value</field>
            <field name="category">value</field>
            <field name="metric_key">avg_order_value</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">500.0</field>
            <field name="score">80</field>
            <field name="weight">1.2</field>
            <field name="sequence">20</field>
            <field name="active">True</field>
        </record>

        <!-- Loyalty: Frequent ordering -->
        <record id="rule_frequent_buyer" model="ll.rating.rule">
            <field name="name">Repeat Buying Cadence</field>
            <field name="category">value</field>
            <field name="metric_key">order_frequency_12m</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">8.0</field>
            <field name="score">70</field>
            <field name="weight">1.0</field>
            <field name="sequence">30</field>
            <field name="active">True</field>
        </record>

        <!-- Financial: Pays close to due date -->
        <record id="rule_fast_payer" model="ll.rating.rule">
            <field name="name">Payment Discipline</field>
            <field name="category">financial</field>
            <field name="metric_key">avg_payment_delay_days</field>
            <field name="threshold_type">lt</field>
            <field name="threshold_min">10.0</field>
            <field name="score">90</field>
            <field name="weight">1.4</field>
            <field name="sequence">40</field>
            <field name="active">True</field>
        </record>

        <!-- Financial: Low open receivable risk -->
        <record id="rule_reliable_payer" model="ll.rating.rule">
            <field name="name">Controlled Outstanding</field>
            <field name="category">financial</field>
            <field name="metric_key">outstanding_amount</field>
            <field name="threshold_type">lt</field>
            <field name="threshold_min">5000.0</field>
            <field name="score">100</field>
            <field name="weight">1.3</field>
            <field name="sequence">50</field>
            <field name="active">True</field>
        </record>

        <!-- Behavioral: Low refund pressure -->
        <record id="rule_low_maintenance" model="ll.rating.rule">
            <field name="name">Low Refund Pressure</field>
            <field name="category">behavioral</field>
            <field name="metric_key">refund_ratio</field>
            <field name="threshold_type">lt</field>
            <field name="threshold_min">0.05</field>
            <field name="score">70</field>
            <field name="weight">1.0</field>
            <field name="sequence">60</field>
            <field name="active">True</field>
        </record>

        <!-- AI: Portfolio-level risk interpretation -->
        <record id="rule_smart_sentiment" model="ll.rating.rule">
            <field name="name">AI Risk Profile</field>
            <field name="category">ai</field>
            <field name="metric_key">risk_score</field>
            <field name="threshold_type">lt</field>
            <field name="threshold_min">40.0</field>
            <field name="score">100</field>
            <field name="weight">1.5</field>
            <field name="sequence">70</field>
            <field name="active">True</field>
        </record>

        <!-- AI: Loyalty interpretation -->
        <record id="rule_ai_loyalty" model="ll.rating.rule">
            <field name="name">AI Loyalty Signal</field>
            <field name="category">ai</field>
            <field name="metric_key">loyalty_score</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">60.0</field>
            <field name="score">80</field>
            <field name="weight">1.0</field>
            <field name="sequence">80</field>
            <field name="active">True</field>
        </record>

        <!-- AI: Financial health interpretation -->
        <record id="rule_ai_financial_health" model="ll.rating.rule">
            <field name="name">AI Financial Health</field>
            <field name="category">ai</field>
            <field name="metric_key">financial_health</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">65.0</field>
            <field name="score">90</field>
            <field name="weight">1.2</field>
            <field name="sequence">90</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
