<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Revenue Rule -->
        <record id="rule_revenue_giant" model="ll.rating.rule">
            <field name="name">Revenue Giant</field>
            <field name="category">value</field>
            <field name="metric_key">revenue</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">10000.0</field>
            <field name="score">100</field>
            <field name="weight">2.0</field>
            <field name="sequence">10</field>
            <field name="active">True</field>
        </record>

        <!-- AUP Rule -->
        <record id="rule_luxury_buyer" model="ll.rating.rule">
            <field name="name">Luxury Buyer (AUP)</field>
            <field name="category">value</field>
            <field name="metric_key">aup</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">500.0</field>
            <field name="score">100</field>
            <field name="weight">1.5</field>
            <field name="sequence">20</field>
            <field name="active">True</field>
        </record>

        <!-- Frequency Rule -->
        <record id="rule_frequent_buyer" model="ll.rating.rule">
            <field name="name">Frequent Buyer</field>
            <field name="category">value</field>
            <field name="metric_key">frequency</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">5.0</field>
            <field name="score">100</field>
            <field name="weight">1.0</field>
            <field name="sequence">30</field>
            <field name="active">True</field>
        </record>

        <!-- DSO Rule -->
        <record id="rule_fast_payer" model="ll.rating.rule">
            <field name="name">Fast Payer (DSO)</field>
            <field name="category">financial</field>
            <field name="metric_key">dso</field>
            <field name="threshold_type">lt</field>
            <field name="threshold_min">15.0</field>
            <field name="score">50</field>
            <field name="weight">1.0</field>
            <field name="sequence">40</field>
            <field name="active">False</field>
        </record>

        <!-- Overdue Rule -->
        <record id="rule_reliable_payer" model="ll.rating.rule">
            <field name="name">Reliable Payer (Overdue)</field>
            <field name="category">financial</field>
            <field name="metric_key">overdue</field>
            <field name="threshold_type">lt</field>
            <field name="threshold_min">100.0</field>
            <field name="score">100</field>
            <field name="weight">1.0</field>
            <field name="sequence">50</field>
            <field name="active">False</field>
        </record>

        <!-- Returns Rule -->
        <record id="rule_low_maintenance" model="ll.rating.rule">
            <field name="name">Low Maintenance (Returns)</field>
            <field name="category">behavioral</field>
            <field name="metric_key">returns</field>
            <field name="threshold_type">lt</field>
            <field name="threshold_min">5.0</field>
            <field name="score">50</field>
            <field name="weight">1.0</field>
            <field name="sequence">60</field>
            <field name="active">False</field>
        </record>

        <!-- AI Sentiment Rule -->
        <record id="rule_smart_sentiment" model="ll.rating.rule">
            <field name="name">Smart Sentiment (AI)</field>
            <field name="category">ai</field>
            <field name="metric_key">sentiment</field>
            <field name="threshold_type">gt</field>
            <field name="threshold_min">70.0</field>
            <field name="score">100</field>
            <field name="weight">0.5</field>
            <field name="sequence">70</field>
            <field name="active">False</field>
        </record>
    </data>
</odoo>
